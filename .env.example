# ─────────────────────────────────────────────────────────────────────────────
# Cloud Governance Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_VERSION=1.0.0
SECRET_KEY=dev-secret-key-change-in-production-must-be-32-chars-min
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
# Used by backend. Postgres service name 'postgres' when running in Docker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cloudaudit
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── AWS Configuration ────────────────────────────────────────────────────────
# Set MOCK_AWS=true to run without real credentials (returns realistic dummy data).
# Set MOCK_AWS=false and provide real credentials to scan actual AWS resources.
MOCK_AWS=true

AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# For cross-account scanning via IAM role assumption:
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/CloudAuditScannerRole

# ── Scanner Settings ──────────────────────────────────────────────────────────
# Comma-separated list of regions to scan
SCAN_REGIONS=us-east-1,us-west-2

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Slack Integration (optional) ──────────────────────────────────────────────
# Set this to post audit reports to a Slack channel.
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
# Usage: python scripts/report.py --slack
#        python scripts/report.py -o report.json --slack
SLACK_WEBHOOK_URL=
